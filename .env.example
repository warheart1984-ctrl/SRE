# Sovereign Reconstruction Engine — environment variables
# Copy to .env and adjust for local development.

# --- HTTP API (sre-api / python -m sre.api) ---
SRE_API_HOST=127.0.0.1
SRE_API_PORT=8010
# SRE_API_RELOAD=true

# --- Corpus data directory (optional) ---
# Override when running from an installed wheel without repo-root data/
# SRE_DATA_DIR=/path/to/sovereign-reconstruction-engine/data

# --- CEL evidence ledger persistence ---
# SRE_CEL_STORE_PATH=.sre/cel_store.json

# --- Dantomax local signing (development only) ---
# SRE_DANTOMAX_KEY=change-me-in-production

# --- KMS (production signing) ---
# SRE_KMS_MODE=local
# SRE_KMS_MODE=remote
# SRE_KMS_URL=https://kms.example.com/v1/sign
# SRE_KMS_AUTH=Bearer <token>
