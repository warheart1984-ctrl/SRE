# Sovereign Reconstruction Engine — environment variables
# Copy to .env and adjust for local development.

# --- HTTP API (sre-api / python -m sre.api) ---
SRE_API_HOST=127.0.0.1
SRE_API_PORT=8010
# SRE_API_RELOAD=true

# --- API authentication (production) ---
# Comma-separated API keys; clients send X-API-Key or Authorization: Bearer <key>
# SRE_API_KEYS=dev-key-change-me,rotate-in-production
# SRE_API_AUTH_REQUIRED=false

# --- TLS ---
# Terminate TLS at Caddy/nginx — see deploy/Caddyfile.example and deploy/nginx.conf.example
# Keep SRE_API_HOST=127.0.0.1 behind the reverse proxy.

# --- Durable store (evidence + reconstructions) ---
# SRE_STORE_BACKEND=memory
# SRE_STORE_BACKEND=sqlite
# SRE_SQLITE_PATH=.sre/sre.db
# SRE_STORE_BACKEND=postgres
# SRE_DATABASE_URL=postgresql://user:pass@localhost:5432/sre

# --- Corpus data directory (optional) ---
# Override when running from an installed wheel without repo-root data/
# SRE_DATA_DIR=/path/to/sovereign-reconstruction-engine/data

# --- CEL evidence ledger persistence ---
# SRE_CEL_STORE_PATH=.sre/cel_store.jsonl

# --- Dantomax local signing (development only) ---
# SRE_DANTOMAX_KEY=change-me-in-production

# --- KMS (production signing) ---
# SRE_KMS_MODE=local
# SRE_KMS_MODE=remote
# SRE_KMS_URL=http://127.0.0.1:8020/v1/sign
# SRE_KMS_AUTH=Bearer <token>
# Dev KMS server: python scripts/kms_sign_server.py

# --- AI analyzer backend ---
# SRE_ANALYZER_BACKEND=rule
# SRE_ANALYZER_BACKEND=statistical
# SRE_ANALYZER_BACKEND=ml
# Built-in ML providers:
# SRE_ML_PROVIDER=ngram
# SRE_ML_PROVIDER=llm
# SRE_ML_PROVIDER=none
#
# LLM (OpenAI-compatible chat completions):
# Free local (no API key): install Ollama, then:
#   ollama pull llama3.2:3b
# SRE_ML_PROVIDER=llm
# SRE_LLM_PRESET=ollama
# SRE_LLM_MODEL=llama3.2:3b
#
# Free-tier cloud (requires a free API key):
# SRE_LLM_PRESET=openrouter-free
# SRE_LLM_API_KEY=...   # or OPENROUTER_API_KEY
# SRE_LLM_PRESET=groq
# SRE_LLM_API_KEY=...   # or GROQ_API_KEY
#
# Explicit endpoint (overrides preset URL):
# SRE_LLM_URL=https://api.openai.com/v1/chat/completions
# SRE_LLM_API_KEY=sk-...
# SRE_LLM_MODEL=gpt-4o-mini
# Local mock: python scripts/llm_mock_server.py
# SRE_LLM_URL=http://127.0.0.1:8030/v1/chat/completions
