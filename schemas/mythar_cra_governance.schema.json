{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MytharCRAGovernance",
  "description": "CRA-aligned governance record for Mythar roots and clusters (LRL-INV-05).",
  "type": "object",
  "required": [
    "identity",
    "justification_dependency",
    "evidence_dependency",
    "assurance_level",
    "lifecycle_state",
    "cel_lineage",
    "revision_history"
  ],
  "properties": {
    "identity": { "type": "string", "minLength": 1 },
    "kind": { "type": "string", "enum": ["root", "cluster"] },
    "justification_dependency": { "type": "string", "minLength": 1 },
    "evidence_dependency": { "type": "string", "minLength": 1 },
    "assurance_level": {
      "type": "string",
      "enum": ["experimental", "candidate", "validated"]
    },
    "lifecycle_state": {
      "type": "string",
      "enum": ["Draft", "Review", "Ratified", "Active"]
    },
    "cel_lineage": {
      "type": "object",
      "required": ["binding_status", "subject_id"],
      "properties": {
        "binding_status": {
          "type": "string",
          "enum": ["bound", "deferred", "placeholder"]
        },
        "subject_id": { "type": "string", "minLength": 1 },
        "cel_entry_id": { "type": ["string", "null"] },
        "entry_type_hint": { "type": "string" },
        "charter_ref": { "type": "string" },
        "bind_when": { "type": "string" },
        "kind": { "type": "string" }
      }
    },
    "revision_history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["version", "timestamp", "change", "rationale"],
        "properties": {
          "version": { "type": "string" },
          "timestamp": { "type": "string" },
          "change": { "type": "string" },
          "rationale": { "type": "string" },
          "refs": { "type": "string" }
        }
      }
    },
    "cra_refs": { "type": "object" }
  }
}
